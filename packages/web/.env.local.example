# remex.mx — Frontend Environment Variables
# Copy to .env.local and fill values

# API
NEXT_PUBLIC_API_URL=http://localhost:3001

# Base L2 — testnet or mainnet
NEXT_PUBLIC_NETWORK=testnet
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
NEXT_PUBLIC_BASE_RPC_URL=https://sepolia.base.org
NEXT_PUBLIC_BASESCAN_URL=https://sepolia.basescan.org

# Persona KYC
NEXT_PUBLIC_PERSONA_TEMPLATE_ID=itmpl_...
NEXT_PUBLIC_PERSONA_ENV=sandbox
