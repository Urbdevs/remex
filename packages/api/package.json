{
  "name": "@remex/api",
  "version": "1.0.0",
  "description": "RemexBridge backend API — Node.js + Fastify",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "node -r tsx/cjs src/db/migrate.ts",
    "db:seed": "node -r tsx/cjs src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "axios": "^1.6.0",
    "bullmq": "^5.4.0",
    "dotenv": "^16.0.0",
    "fastify": "^4.26.0",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.3.0",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "postgres": "^3.4.0",
    "viem": "^2.7.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.1.6",
    "vitest": "^1.4.0"
  }
}
